@startuml
title GameDuck Backend ↔ Frontend Architecture

package "Frontend" as FE {
    class MainWindow
    class DuckDisplay
    class InputRouter
    class OptionsWindow
    class CheatManagerWindow
    class SaveStateManagerWindow
}

package "Backend Platform API" as API {
    interface EmulatorBackend
    interface EmulatorProfile
    interface EmulatorRuntime
    interface EmulatorHost
    interface EmulatorGame
    class EmulatorCheat
    class EmulatorStateSlot
}

package "Backend GB" as GB {
    class GBBackends
    class DuckBackend
    class DuckEmulation
    class DuckCPU
    class DuckMemory
    class DuckTimer
    class DuckPPU
    class DuckAPU
    class DuckJoypad
    class CheatEngine
}

package "Backend Helpers" as H {
    class SaveFileManager
    class QuickStateManager
    class ManagedGameRegistry
    class CheatStore
    class GameLibraryStore
}

FE.MainWindow --> API.EmulatorBackend : uses
FE.MainWindow --> API.EmulatorHost : implements
FE.MainWindow --> FE.DuckDisplay : owns
FE.MainWindow --> GB.DuckEmulation : creates
FE.InputRouter --> API.EmulatorRuntime : calls SetButtonPressed()
FE.OptionsWindow --> API.EmulatorProfile : reads profile/capabilities
FE.CheatManagerWindow --> API.EmulatorRuntime : manages cheats
FE.SaveStateManagerWindow --> API.EmulatorRuntime : save/load states

API.EmulatorBackend <|.. GB.DuckBackend
GB.GBBackends --> API.EmulatorBackend : current backend
GB.DuckBackend --> API.EmulatorProfile : returns DuckProfile
GB.DuckBackend --> API.EmulatorRuntime : CreateRuntime()

GB.DuckEmulation --> GB.DuckCPU
GB.DuckEmulation --> GB.DuckMemory
GB.DuckEmulation --> GB.DuckTimer
GB.DuckEmulation --> GB.DuckPPU
GB.DuckEmulation --> GB.DuckAPU
GB.DuckEmulation --> GB.DuckJoypad
GB.DuckEmulation --> GB.CheatEngine

GB.DuckEmulation --> H.SaveFileManager : manage save data
GB.DuckEmulation --> H.QuickStateManager : save/load states
GB.DuckEmulation --> H.ManagedGameRegistry : remember games
GB.DuckEmulation --> H.CheatStore : load/save cheats
GB.DuckEmulation --> H.GameLibraryStore : remember games

API.EmulatorRuntime --> API.EmulatorGame : returns loaded game
API.EmulatorRuntime --> API.EmulatorCheat : describes cheats
API.EmulatorRuntime --> API.EmulatorStateSlot : describes slots

@enduml